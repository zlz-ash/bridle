# ===== Information Radar 环境变量模板 =====
# 复制为 .env 并填入真实值，.env 不进入 Git 和日志。

# ---- 网络代理（本机 7890）----
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,rsshub,wechat-mp-rss,freshrss,paper-bridge

# ---- 调度 ----
RADAR_CRON="30 8 * * *"
TZ=Asia/Shanghai

# ---- 数据库与目录（容器内路径，由 D 盘卷挂载）----
RADAR_DB_PATH=/app/data/radar.db
RADAR_DATA_DIR=/app/data
RADAR_LOG_DIR=/app/logs
RADAR_REPORT_DIR=/app/data/reports

# ---- AI（OpenAI SDK，便于后续切换底层模型）----
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
RADAR_MODEL=gpt-4o-mini
RADAR_COST_LIMIT_USD=2.0
RADAR_SUMMARY_MAX_TOKENS=1200

# ---- 飞书机器人 ----
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me
FEISHU_ALERT_WEBHOOK=

# ---- FreshRSS ----
FRESHRSS_URL=http://freshrss:80
FRESHRSS_API_USER=admin
FRESHRSS_API_PASSWORD=replace-me

# ---- Zotero（Web API）----
ZOTERO_USER_ID=0000000
ZOTERO_API_KEY=replace-me
ZOTERO_COLLECTION_ID=replace-me

# ---- RSSHub / WeWe-RSS ----
BILIBILI_UIDS=12345678,87654321
WEWE_RSS_TOKEN=replace-me

# ---- 行为开关 ----
RADAR_NOTIFY_ON_EMPTY=true
RADAR_FAILURE_ALERT_DAYS=2
